{
  "name": "hoi4modutilities",
  "displayName": "%hoi4modutilities.displayName%",
  "description": "Utilities for Heart of Iron IV mods developers",
  "version": "0.13.8",
  "author": "server (forked from Chaofan Yang)",
  "publisher": "server",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atlantropa-hoi4/hoi4modutilities"
  },
  "bugs": {
    "url": "https://github.com/Atlantropa-hoi4/hoi4modutilities/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "mod",
    "paradox",
    "hoi",
    "Heart of Iron"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:plaintext",
    "onLanguage:hoi4",
    "onLanguage:paradox",
    "onLanguage:yaml",
    "onCommand:server.hoi4modutilities.preview",
    "onCommand:server.hoi4modutilities.previewworld",
    "onCommand:server.hoi4modutilities.scanreferences",
    "onCommand:server.hoi4modutilities.selectmodfile",
    "onCommand:server.hoi4modutilities.selecthoifolder",
    "onCustomEditor:server.hoi4modutilities.dds",
    "onCustomEditor:server.hoi4modutilities.tga",
    "onWebviewPanel:server.hoi4ftpreview",
    "onWebviewPanel:server.hoi4worldmappreview",
    "workspaceContains:**/*.gfx",
    "workspaceContains:common/national_focus/*.txt",
    "workspaceContains:common/technologies/*.txt",
    "workspaceContains:events/*.txt",
    "workspaceContains:map/default.map"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "locale": "%hoi4modutilities.locale%",
  "contributes": {
    "configuration": [
      {
        "title": "%hoi4modutilities.displayName%",
        "properties": {
          "hoi4ModUtilities.installPath": {
            "title": "%hoi4modutilities.installPath.title%",
            "type": "string",
            "default": "",
            "description": "%hoi4modutilities.installPath.desc%"
          },
          "hoi4ModUtilities.loadDlcContents": {
            "title": "%hoi4modutilities.loadDlcContents.title%",
            "type": "boolean",
            "default": true,
            "description": "%hoi4modutilities.loadDlcContents.desc%"
          },
          "hoi4ModUtilities.modFile": {
            "title": "%hoi4modutilities.modFile.title%",
            "type": "string",
            "default": "",
            "description": "%hoi4modutilities.modFile.desc%"
          },
          "hoi4ModUtilities.enableSupplyArea": {
            "title": "%hoi4modutilities.enableSupplyArea.title%",
            "type": "boolean",
            "default": false,
            "description": "%hoi4modutilities.enableSupplyArea.desc%"
          },
          "hoi4ModUtilities.previewLocalisation": {
            "title": "%hoi4modutilities.previewLocalisation.title%",
            "type": "string",
            "default": "English",
            "enum": [
              "Brazilian Portuguese",
              "English",
              "French",
              "German",
              "Korean",
              "Japanese",
              "Polish",
              "Russian",
              "Simplified Chinese",
              "Spanish"
            ],
            "description": "%hoi4modutilities.previewLocalisation.desc%"
          },
          "hoi4ModUtilities.featureFlags": {
            "title": "%hoi4modutilities.featureFlags.title%",
            "type": "array",
            "default": [],
            "description": "%hoi4modutilities.featureFlags.desc%"
          },
          "hoi4ModUtilities.focusLayoutEditor": {
            "title": "%hoi4modutilities.focusLayoutEditor.title%",
            "type": "boolean",
            "default": false,
            "description": "%hoi4modutilities.focusLayoutEditor.desc%"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "server.hoi4modutilities.preview",
        "title": "%hoi4modutilities.preview.title%",
        "icon": {
          "dark": "static/preview-right-dark.svg",
          "light": "static/preview-right-light.svg"
        },
        "category": "%hoi4modutilities.category%"
      },
      {
        "command": "server.hoi4modutilities.selectmodfile",
        "title": "%hoi4modutilities.selectmodfile.title%",
        "category": "%hoi4modutilities.category%"
      },
      {
        "command": "server.hoi4modutilities.previewworld",
        "title": "%hoi4modutilities.previewworld.title%",
        "category": "%hoi4modutilities.category%"
      },
      {
        "command": "server.hoi4modutilities.scanreferences",
        "title": "%hoi4modutilities.scanreferences.title%",
        "icon": "$(references)",
        "category": "%hoi4modutilities.category%"
      },
      {
        "command": "server.hoi4modutilities.selecthoifolder",
        "title": "%hoi4modutilities.selecthoifolder.title%",
        "category": "%hoi4modutilities.category%"
      },
      {
        "command": "server.hoi4modutilities.test",
        "title": "HOI4 test",
        "category": "%hoi4modutilities.category%"
      }
    ],
    "customEditors": [
      {
        "viewType": "server.hoi4modutilities.dds",
        "displayName": "%hoi4modutilities.dds.editorName%",
        "selector": [
          {
            "filenamePattern": "*.dds"
          }
        ]
      },
      {
        "viewType": "server.hoi4modutilities.tga",
        "displayName": "%hoi4modutilities.tga.editorName%",
        "selector": [
          {
            "filenamePattern": "*.tga"
          }
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "server.hoi4modutilities.preview",
          "when": "resourceScheme != webview-panel && resourceExtname =~ /^\\.(txt|gfx|gui|map)$/ && !server.shouldHideHoi4Preview && !server.shouldShowHoi4Preview",
          "group": "navigation"
        },
        {
          "command": "server.hoi4modutilities.preview",
          "when": "server.shouldShowHoi4Preview && resourceScheme != webview-panel",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "server.hoi4modutilities.preview",
          "when": "resourceScheme != webview-panel && (!server.hoi4MULoaded || server.shouldShowHoi4Preview || resourceExtname =~ /^\\.(txt|gfx|gui|map)$/)"
        },
        {
          "command": "server.hoi4modutilities.scanreferences",
          "when": "!server.hoi4MULoaded || server.hoi4PreviewType == event"
        },
        {
          "command": "server.hoi4modutilities.selectmodfile"
        },
        {
          "command": "server.hoi4modutilities.previewworld"
        },
        {
          "command": "server.hoi4modutilities.selecthoifolder"
        },
        {
          "command": "server.hoi4modutilities.test",
          "when": "server.hoi4MUInDev"
        }
      ]
    }
  },
  "scripts": {
    "clean": "rimraf dist out static .vscode-test",
    "compile-ts": "tsc -p ./ --pretty false",
    "watch": "tsc -w -p ./",
    "webpack": "webpack --mode development",
    "webpack-dev": "webpack --mode development --watch --progress",
    "package:dist": "webpack --mode production",
    "vscode:prepublish": "npm run clean && npm run package:dist",
    "lint": "eslint src webviewsrc test --ext .ts",
    "test:unit": "mocha --exit --recursive \"out/test/unit/**/*.test.js\"",
    "test": "npm run compile-ts && npm run lint && npm run test:unit",
    "test-ui": "npm run compile-ts && vscode-test --config .vscode-test.mjs",
    "package": "vsce package --no-dependencies",
    "verify": "npm run test && npm run test-ui && npm run package",
    "geni18n": "npm run compile-ts && node scripts/genzhi18n.js"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.24",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.57.1",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "@vscode/extension-telemetry": "^1.5.1",
    "adm-zip": "^0.5.16",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.21",
    "pngjs": "^7.0.0",
    "rxjs": "^7.8.2",
    "tga": "^1.0.7",
    "tslib": "^2.8.1"
  }
}
